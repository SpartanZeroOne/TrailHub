# ===========================================
# TrailHub – Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your keys.

# Mapbox – Get your token at https://mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Convex – Set up at https://convex.dev
VITE_CONVEX_URL=your_convex_deployment_url_here

# Supabase – Set up at https://supabase.com
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Services (server-side only, used via Convex actions)
# ANTHROPIC_API_KEY=your_key_here
# FIRECRAWL_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
